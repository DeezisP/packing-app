{
  "name": "packing-recorder",
  "version": "1.1.0",
  "description": "Offline Windows packing video recorder controlled by USB barcode scanners",
  "main": "out/main/index.js",
  "author": "Packing Recorder",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:dir": "npm run build && electron-builder --win --dir --publish never",
    "release": "npm run build && dotenv -e .env -- electron-builder --win --publish always"
  },
  "dependencies": {
    "check-disk-space": "^3.4.0",
    "electron-updater": "^6.3.4",
    "ffmpeg-static": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.9",
    "@types/sql.js": "^1.4.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "dotenv-cli": "^7.4.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
